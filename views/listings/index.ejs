<% layout("/layouts/boilerplate") %>

<style>
  #filters {
    display: flex;
    flex-wrap: wrap;
    overflow-x: auto;
    align-items: center;
  }

  .filters-wrapper {
    display: flex;
    flex-wrap: nowrap;
    align-items: center;
  }

  .filter {
    text-align: center;
    margin-right: 2rem;
    margin-top: 2rem;
    opacity: 0.6;
    transition: 0.2s;
  }

  .filter:hover {
    opacity: 1;
    cursor: pointer;
  }
  .filters::-webkit-scrollbar {
    display: none;
   }

  .filter p {
    font-size: 0.8rem;
    margin-bottom: 0;
  }

  .filter-link {
    text-decoration: none;
    color: inherit;
  }

  .active-filter {
    opacity: 1;
    font-weight: 600;
  }

  .tax-info {
    display: none;
    color: green;
    font-weight: 500;
  }

  .tax-toggle {
    border: 1px solid black;
    border-radius: 1rem;
    height: 3.5rem;
    padding: 0 1rem;
    display: flex;
    align-items: center;
    margin-left: 2rem;
    margin-top: 2rem;
  }
</style>

<!-- FILTERS SECTION -->
<div id="filters">

  <% 
    const selectedCategory = typeof category !== "undefined" ? category : ""; 
    const categories = [
      {key:"trending", label:"Trending", icon:"fa-fire"},
      {key:"rooms", label:"Rooms", icon:"fa-bed"},
      {key:"iconic-cities", label:"Iconic cities", icon:"fa-mountain-city"},
      {key:"mountains", label:"Mountains", icon:"fa-mountain"},
      {key:"castles", label:"Castles", icon:"fa-fort-awesome"},
      {key:"amazing-pools", label:"Amazing Pools", icon:"fa-person-swimming"},
      {key:"camping", label:"Camping", icon:"fa-campground"},
      {key:"farms", label:"Farms", icon:"fa-cow"},
      {key:"arctic", label:"Arctic", icon:"fa-snowflake"},
    ]; 
  %>

  <div class="filters-wrapper">
    <% categories.forEach(cat => { %>
      <a href="/listings<%= cat.key ? '?category=' + cat.key : '' %>" class="filter-link">
        <div class="filter <%= selectedCategory === cat.key ? 'active-filter' : '' %>">
          <div><i class="fa-solid <%= cat.icon %>"></i></div>
          <p><%= cat.label %></p>
        </div>
      </a>
    <% }) %>
  </div>

  <!-- TAX TOGGLE -->
  <div class="tax-toggle">
    <div class="form-check-reverse form-switch">
      <input class="form-check-input" type="checkbox" role="switch" id="switchCheckDefault">
      <label class="form-check-label" for="switchCheckDefault">
        Display total after taxes
      </label>
    </div>
  </div>

</div>

<!-- LISTINGS -->
<div class="row row-cols-lg-4 row-cols-md-3 row-cols-sm-1 mt-3">

  <% if (!listings || listings.length === 0) { %>
    <div class="col-12 text-center mt-5">
      <h5>No listings found.</h5>
    </div>
  <% } else { %>

    <% listings.forEach(listing => { %>
      <a href="/listings/<%= listing._id %>" class="listing-link">
        <div class="card col listing-card">

          <% if(listing.image && listing.image.url) { %>
            <img src="<%= listing.image.url %>" 
                 class="card-img-top" 
                 alt="listing_image"
                 style="height:20rem; object-fit:cover;" />
          <% } else { %>
            <img src="https://via.placeholder.com/400x300" 
                 class="card-img-top"
                 style="height:20rem; object-fit:cover;" />
          <% } %>

          <div class="card-body">
            <p class="card-text">
              <b><%= listing.title %></b><br>

              ₹<%= listing.price.toLocaleString("en-IN") %> / night

              <span class="tax-info">
                &nbsp;&nbsp;₹<%= Math.round(listing.price * 1.18).toLocaleString("en-IN") %> total
              </span>
            </p>
          </div>

        </div>
      </a>
    <% }) %>

  <% } %>

</div>

<!-- TAX TOGGLE SCRIPT -->
<script>
  const taxSwitch = document.getElementById("switchCheckDefault");

  if (taxSwitch) {
    taxSwitch.addEventListener("click", () => {
      const taxInfo = document.getElementsByClassName("tax-info");

      for (let info of taxInfo) {
        info.style.display =
          info.style.display !== "inline" ? "inline" : "none";
      }
    });
  }
</script>